{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and all runtime windows",
  "windows": ["main", "main-*"],
  "permissions": [
    "core:default",
    "core:window:allow-destroy",
    "opener:default",
    "dialog:default",
    "updater:default",
    "process:default",
    "window-state:default"
  ]
}
